# Application
APP_NAME=Shipment Bot
DEBUG=false

# CORS (comma-separated). Example:
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=

# Database - PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/shipment_bot

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# WhatsApp Gateway (Node.js microservice with WPPConnect)
WHATSAPP_GATEWAY_URL=http://localhost:3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here
# URL חיצוני לרישום webhook אוטומטי (ב-Render מוגדר אוטומטית דרך RENDER_EXTERNAL_URL)
# TELEGRAM_WEBHOOK_BASE_URL=https://my-app.onrender.com

# Credit settings
DEFAULT_CREDIT_LIMIT=-500.0
DELIVERY_FEE=10.0

# Outbox retry/backoff
# base_seconds * 2**retry_count (capped)
OUTBOX_RETRY_BASE_SECONDS=30
OUTBOX_MAX_BACKOFF_SECONDS=3600

# Sentry — Error Tracking
# DSN מפרויקט Sentry — ריק = Sentry מושבת
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# PostHog — Product Analytics
# API Key מפרויקט PostHog — ריק = PostHog מושבת
# POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# POSTHOG_HOST=https://us.i.posthog.com

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
